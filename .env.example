# EcoVolt Telemetry Dashboard - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# CONVEX
# =============================================================================
# Production URL — also set in .env.production for Vercel builds (optional override here).
VITE_CONVEX_URL=https://wonderful-kookabura-432.convex.cloud
# Optional: override Convex deploy key for backend/maindata.py (defaults are in maindata.py)
# CONVEX_DEPLOY_KEY=

# =============================================================================
# OPTIONAL
# =============================================================================
# MapTiler API key for satellite/terrain map styles (optional)
VITE_MAPTILER_KEY=

# Enable debug logging (optional)
VITE_DEBUG=false
