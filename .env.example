# EcoVolt Telemetry Dashboard - Local Environment Variables
# Copy this file to .env.local and fill in your values. Never commit .env.local.

# =============================================================================
# CONVEX
# =============================================================================
# Production URL — also set in .env.production for Vercel builds (optional override here).
VITE_CONVEX_URL=https://wonderful-kookabura-432.convex.cloud
# Python telemetry bridge only. These values are never bundled into the browser.
ESP32_ABLY_API_KEY=
DASHBOARD_ABLY_API_KEY=
CONVEX_DEPLOY_KEY=
ESP32_CHANNEL_NAME=EcoTele
DASHBOARD_CHANNEL_NAME=telemetry-dashboard-channel

# Convex server environment (configure with `npx convex env set`, not VITE_*):
# ABLY_API_KEY                 server-side Ably key used to mint scoped tokens
# AUTH_PASSWORD_PEPPER        long random secret used by the password KDF
# ALLOWED_WEB_ORIGINS         comma-separated HTTPS application origins

# =============================================================================
# OPTIONAL
# =============================================================================
# MapTiler API key for satellite/terrain map styles (optional)
VITE_MAPTILER_KEY=

# Enable debug logging (optional)
VITE_DEBUG=false
