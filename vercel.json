{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/driver",
      "destination": "/driver.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/dashboard-solid",
      "destination": "/dashboard.html"
    },
    {
      "source": "/dashboard-legacy",
      "destination": "/legacy-dashboard-do-not-use/dashboard.html"
    },
    {
      "source": "/dashboard/sessions",
      "destination": "/historical.html"
    },
    {
      "source": "/historical/custom",
      "destination": "/historical.html"
    },
    {
      "source": "/historical/:sessionId",
      "destination": "/historical.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/lib/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}